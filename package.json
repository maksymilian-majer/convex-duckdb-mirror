{
  "name": "convex-duckdb-mirror-repo",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "bin": {
    "convex-duckdb": "apps/cli/dist/cli.js"
  },
  "workspaces": [
    "apps/*"
  ],
  "scripts": {
    "prepare": "npm run cli:build",
    "cli:build": "npm --workspace convex-duckdb run build",
    "cli:test": "npm --workspace convex-duckdb run test",
    "proxy:dev": "npm --workspace convex-duckdb-proxy run dev",
    "proxy:build": "npm --workspace convex-duckdb-proxy run build",
    "proxy:start": "npm --workspace convex-duckdb-proxy run start",
    "proxy:test": "npm --workspace convex-duckdb-proxy run test",
    "test": "npm run cli:test && npm run proxy:test",
    "build": "npm run cli:build && npm run proxy:build"
  },
  "dependencies": {
    "@duckdb/node-api": "^1.5.3-r.3"
  },
  "devDependencies": {
    "@types/node": "^24.10.1",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3",
    "vitest": "^4.1.8"
  }
}
