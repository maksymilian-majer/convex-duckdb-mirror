{
  "name": "convex-duckdb",
  "version": "0.0.1",
  "description": "Sync a local DuckDB mirror of Convex data for ad-hoc analytics.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/maksymilian-majer/convex-duckdb-mirror.git",
    "directory": "apps/cli"
  },
  "bugs": {
    "url": "https://github.com/maksymilian-majer/convex-duckdb-mirror/issues"
  },
  "homepage": "https://github.com/maksymilian-majer/convex-duckdb-mirror#readme",
  "type": "module",
  "engines": {
    "node": ">=24.0.0"
  },
  "bin": {
    "convex-duckdb-sync": "dist/cli.js"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "test": "vitest run --config vitest.config.ts",
    "cli": "tsx src/cli.ts",
    "sync": "tsx src/cli.ts refresh",
    "sync:full": "tsx src/cli.ts refresh --full",
    "status": "tsx src/cli.ts status"
  },
  "dependencies": {
    "@duckdb/node-api": "^1.5.3-r.3"
  },
  "devDependencies": {
    "@types/node": "^24.10.1",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3",
    "vitest": "^4.1.8"
  }
}
